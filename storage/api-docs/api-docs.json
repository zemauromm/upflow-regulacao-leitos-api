            "get": {
                "tags": [
                    "Internacoes"
                ],
                "summary": "Lista todas as internações",
                "operationId": "1ff8982f940dbc97a1595520395e2888",
                "responses": {
                    "200": {
                        "description": "Lista de internações retornada com sucesso"
                    }
                }
            },
            "post": {
                "tags": [
                    "Internacoes"
                ],
                "summary": "Registra uma nova internação",
                "operationId": "e4be0b3d890290ac19e656acb7bfc757",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "paciente_id",
                                    "leito_id",
                                    "data_internacao"
                                ],
                                "properties": {
                                    "paciente_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "leito_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "data_internacao": {
                                        "type": "string",
                                        "example": "2026-06-17 22:00:00"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Internação registrada com sucesso"
                    },
                    "422": {
                        "description": "Regra de negócio ou validação não atendida"
                    }
                }
            }
        },
